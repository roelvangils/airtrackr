{
    "geocoding": {
        "provider": "nominatim",
        "rate_limit_seconds": 1.1,
        "timeout_seconds": 10,
        "user_agent": "AirTracker/1.0 (https://github.com/user/airtracker)",
        "cache_results": true,
        "cache_duration_days": 7
    },
    "locations": {
        "custom_coordinates": {
            "Home": {
                "latitude": "51,055763244628906",
                "longitude": "3,725496292114258",
                "note": "Replace null values with your home coordinates"
            },
            "office": {
                "latitude": "51,05582",
                "longitude": "3,72538",
                "note": "Replace null values with your office coordinates"
            }
        }
    },
    "contacts": {
        "enabled": true,
        "sync_interval_seconds": 3600
    },
    "database": {
        "backup_enabled": true,
        "backup_interval_hours": 24,
        "vacuum_interval_days": 7,
        "max_size_mb": 100,
        "retention": {
            "raw_data_days": 90,
            "hourly_summary_days": 365,
            "run_interval_hours": 1
        }
    }
}
